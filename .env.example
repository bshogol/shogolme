# DigitalOcean Managed Postgres connection string
DATABASE_URL=postgres://user:password@host:25060/shogol?sslmode=require

# Public URL (used in RSS feed, sitemap, OG tags)
BASE_URL=https://shogol.me

# CORS origins (comma-separated, leave empty for same-origin only)
CORS_ORIGINS=

# Logging
LOG_FORMAT=json
LOG_LEVEL=info
